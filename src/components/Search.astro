---
// src/components/Search.astro
import { withBase } from "@/utils/path";

// SRI hash'i build-time postprocess aşamasında enjekte edilmelidir
const pagefindSRI = import.meta.env.PAGEFIND_SRI || '';
---

<div 
    id="search-modal" 
    class="fixed inset-0 z-[100] flex flex-col items-center justify-start pt-[12vh] px-4 sm:px-6 invisible opacity-0 transition-opacity duration-300 ease-out"
>
    <div 
        id="search-overlay" 
        class="absolute inset-0 bg-[hsl(var(--theme-bg))]/70 backdrop-blur-md cursor-pointer transition-colors duration-300"
    ></div>
    
    <div 
        id="search-panel"
        class="relative w-full max-w-2xl bg-[var(--paper)]/95 backdrop-blur-xl border border-[var(--hairline)] rounded-2xl overflow-hidden shadow-2xl transform scale-[0.97] translate-y-4 transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] z-10 flex flex-col"
    >
        <div class="flex justify-between items-center px-5 py-3 bg-[hsl(var(--theme-bg))]/80 border-b border-[var(--hairline)] transition-colors duration-300">
            <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[var(--faint)] border border-[var(--hairline)]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[hsl(var(--theme-accent))] shadow-[0_0_8px_var(--accent-soft-strong)]"></span>
                <span class="text-[hsl(var(--theme-text-muted))] text-[10px] font-mono uppercase tracking-widest ml-2 transition-colors">Search</span>
            </div>
            <div class="text-[hsl(var(--theme-text-muted))] text-[10px] font-mono uppercase tracking-widest transition-colors">
                <span>[ESC] ABORT</span>
            </div>
        </div>

        <div class="p-4 w-full">
            <div id="pagefind-search" class="w-full font-mono"></div>
        </div>
    </div>
</div>

<script is:inline define:vars={{ pagefindJs: withBase('/pagefind/pagefind-ui.js'), pagefindCss: withBase('/pagefind/pagefind-ui.css'), pagefindSRI }}>
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('search-modal');
        const overlay = document.getElementById('search-overlay');
        const panel = document.getElementById('search-panel');
        let pagefindInstance = null;

        const initPagefind = () => {
            if (pagefindInstance) return;
            try {
                const script = document.createElement('script');
                script.src = pagefindJs;
                
                // Zafiyet Kapatıldı (Finding #8): SRI (Subresource Integrity) Doğrulaması
                if (pagefindSRI) {
                    script.integrity = pagefindSRI;
                    script.crossOrigin = 'anonymous';
                }

                script.onload = () => {
                    pagefindInstance = new window.PagefindUI({
                        element: "#pagefind-search",
                        showSubResults: true,
                        showImages: false,
                        resetStyles: false
                    });
                };
                document.head.appendChild(script);
                
                const link = document.createElement('link');
                link.rel = 'stylesheet';
                link.href = pagefindCss;
                document.head.appendChild(link);
            } catch (error) {
                console.error('[SYS.ERR] Pagefind yüklenemedi:', error);
            }
        };

        const openModal = () => {
            initPagefind();
            
            modal.classList.remove('invisible', 'opacity-0');
            modal.classList.add('visible', 'opacity-100');
            
            panel.classList.remove('scale-[0.97]', 'translate-y-4');
            panel.classList.add('scale-100', 'translate-y-0');
            
            setTimeout(() => {
                const input = document.querySelector('.pagefind-ui__search-input');
                if(input) input.focus();
            }, 100);
        };

        const closeModal = () => {
            panel.classList.remove('scale-100', 'translate-y-0');
            panel.classList.add('scale-[0.97]', 'translate-y-4');
            
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0');
            
            setTimeout(() => {
                modal.classList.remove('visible');
                modal.classList.add('invisible');
                
                const clearBtn = document.querySelector('.pagefind-ui__search-clear');
                if (clearBtn) clearBtn.click();
            }, 300);
        };

        window.addEventListener('keydown', (e) => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                openModal();
            }
            if (e.key === 'Escape' && modal.classList.contains('visible')) {
                closeModal();
            }
        });

        overlay?.addEventListener('click', closeModal);
    });
</script>